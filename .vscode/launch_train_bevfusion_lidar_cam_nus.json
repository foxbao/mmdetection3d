{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "BEVFusion Single GPU Debug (nuScenes)",
        "type": "debugpy",
        "request": "launch",
        "program": "${workspaceFolder}/tools/train.py",
        "console": "integratedTerminal",
        "justMyCode": false,
        "env": {
          "PYTHONPATH": "${workspaceFolder}"
        },
        "args": [
          "projects/BEVFusion/configs/bevfusion_lidar-cam_voxel0075_second_secfpn_8xb4-cyclic-20e_nus-3d.py",
          "--cfg-options",
          "load_from=work_dirs/bevfusion_lidar_voxel0075_second_secfpn_8xb4-cyclic-20e_nus-3d/epoch_20.pth",
          "model.img_backbone.init_cfg.checkpoint=pretrained/swint-nuimages-pretrained.pth"
        ]
      }
    ]
  }
  